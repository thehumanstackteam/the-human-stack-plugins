#!/usr/bin/env npx ts-node
// Architect Context System - Context Query
// Queries pgvector for relevant session context

import { readFileSync, existsSync } from 'fs';
import { config, validateConfig } from './config';

// Types
interface QueryOptions {
  projectName?: string;
  featureName?: string;
  layers?: string[];
  sublayers?: string[];
  productArea?: string;
  limit?: number;
  includeContent?: boolean;
}

interface ContextResult {
  layer: string;
  sublayer: string;
  summary: string;
  content?: string;
  productArea: string | null;
  sessionName: string;
  sessionDate: string;
  similarity: number;
}

// Validate embedding is array of finite numbers (prevents injection)
function validateEmbedding(embedding: unknown): number[] {
  if (!Array.isArray(embedding)) {
    throw new Error('Embedding must be an array');
  }
  for (const val of embedding) {
    if (typeof val !== 'number' || !isFinite(val)) {
      throw new Error('Embedding values must be finite numbers');
    }
  }
  return embedding as number[];
}

// Generate embedding for query
async function embedQuery(text: string): Promise<number[]> {
  const response = await fetch('https://api.openai.com/v1/embeddings', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${config.openai.apiKey}`,
    },
    body: JSON.stringify({
      model: config.openai.embeddingModel,
      input: text,
    }),
  });

  // Check response status
  if (!response.ok) {
    const errorText = await response.text();
    throw new Error(`Embedding API error ${response.status}: ${errorText}`);
  }

  const data = await response.json();

  // Validate embedding before returning
  return validateEmbedding(data.data[0].embedding);
}

// Query the database
async function queryDatabase(
  queryEmbedding: number[],
  options: QueryOptions
): Promise<ContextResult[]> {
  const { Pool } = await import('pg');
  const pool = new Pool({ connectionString: config.database.url });

  try {
    const limit = Math.min(
      Math.max(1, options.limit || config.query.defaultLimit),
      100 // Cap at 100 to prevent abuse
    );

    // Validate embedding (defense in depth)
    const validatedEmbedding = validateEmbedding(queryEmbedding);
    const embeddingStr = `[${validatedEmbedding.join(',')}]`;

    // Build WHERE clause with parameterized values
    const conditions: string[] = [];
    const params: any[] = [embeddingStr];
    let paramIndex = 2;

    // Project filter: include specified project OR cross-project layers
    if (options.projectName) {
      const crossLayers = config.query.crossProjectLayers;
      conditions.push(`(project_name = $${paramIndex} OR layer = ANY($${paramIndex + 1}))`);
      params.push(options.projectName, crossLayers);
      paramIndex += 2;
    }

    // Layer filter
    if (options.layers && options.layers.length > 0) {
      conditions.push(`layer = ANY($${paramIndex})`);
      params.push(options.layers);
      paramIndex++;
    }

    // Sublayer filter
    if (options.sublayers && options.sublayers.length > 0) {
      conditions.push(`sublayer = ANY($${paramIndex})`);
      params.push(options.sublayers);
      paramIndex++;
    }

    // Product area filter
    if (options.productArea) {
      conditions.push(`product_area = $${paramIndex}`);
      params.push(options.productArea);
      paramIndex++;
    }

    // Parameterize LIMIT
    params.push(limit);
    const limitParam = `$${paramIndex}`;

    const whereClause = conditions.length > 0 ? `WHERE ${conditions.join(' AND ')}` : '';

    const query = `
      SELECT
        layer,
        sublayer,
        summary,
        ${options.includeContent ? 'content,' : ''}
        product_area,
        session_name,
        session_date,
        1 - (embedding_vec <-> $1::vector) as similarity
      FROM session_embeddings
      ${whereClause}
      ORDER BY embedding_vec <-> $1::vector
      LIMIT ${limitParam}
    `;

    const result = await pool.query(query, params);

    return result.rows.map(row => ({
      layer: row.layer,
      sublayer: row.sublayer,
      summary: row.summary,
      content: row.content,
      productArea: row.product_area,
      sessionName: row.session_name,
      sessionDate: row.session_date,
      similarity: parseFloat(row.similarity),
    }));
  } finally {
    await pool.end();
  }
}

// Format results for Claude context injection
function formatForContext(results: ContextResult[]): string {
  if (results.length === 0) {
    return '';
  }

  const grouped: Record<string, ContextResult[]> = {};
  for (const result of results) {
    const key = `${result.layer}/${result.sublayer}`;
    if (!grouped[key]) grouped[key] = [];
    grouped[key].push(result);
  }

  let output = '## Relevant Context from Previous Sessions\n\n';

  for (const [key, items] of Object.entries(grouped)) {
    const [layer, sublayer] = key.split('/');
    output += `### ${capitalize(layer)} - ${capitalize(sublayer)}\n\n`;

    for (const item of items) {
      output += `- ${item.summary}`;
      if (item.productArea) output += ` [${item.productArea}]`;
      output += ` _(${item.sessionDate})_\n`;
    }
    output += '\n';
  }

  return output;
}

function capitalize(s: string): string {
  return s.charAt(0).toUpperCase() + s.slice(1);
}

// Build query text from project context
function buildQueryFromProject(projectDir: string): string {
  const parts: string[] = [];

  // Read active.md if exists
  const activePath = `${projectDir}/docs/architect/project/active.md`;
  if (existsSync(activePath)) {
    const active = readFileSync(activePath, 'utf-8');
    parts.push(active.slice(0, 1000)); // First 1000 chars
  }

  // Read current session name if exists
  const sessionPath = `${projectDir}/docs/architect/.current-session`;
  if (existsSync(sessionPath)) {
    const sessionName = readFileSync(sessionPath, 'utf-8').trim();
    parts.push(`Current feature: ${sessionName}`);
  }

  // Fallback to project name
  if (parts.length === 0) {
    parts.push(config.project.name);
  }

  return parts.join('\n\n');
}

// Main query function
export async function queryContext(
  queryText: string,
  options: QueryOptions = {}
): Promise<string> {
  const validation = validateConfig();
  if (!validation.valid) {
    console.error(`Missing config: ${validation.missing.join(', ')}`);
    return '';
  }

  // Generate embedding for query
  const queryEmbedding = await embedQuery(queryText);

  // Query database
  const results = await queryDatabase(queryEmbedding, {
    ...options,
    projectName: options.projectName || config.project.name,
  });

  // Filter by similarity threshold
  const filtered = results.filter(r => r.similarity >= config.query.minSimilarity);

  // Format for context
  return formatForContext(filtered);
}

// Query specific layers
export async function queryByLayer(
  layer: string,
  sublayer?: string,
  options: QueryOptions = {}
): Promise<ContextResult[]> {
  const validation = validateConfig();
  if (!validation.valid) {
    return [];
  }

  // Build a generic query for the layer
  const queryText = `${layer} ${sublayer || ''} context`;
  const queryEmbedding = await embedQuery(queryText);

  return queryDatabase(queryEmbedding, {
    ...options,
    layers: [layer],
    sublayers: sublayer ? [sublayer] : undefined,
    includeContent: true,
  });
}

// CLI entry point
const args = process.argv.slice(2);
if (args.length > 0) {
  const mode = args[0];

  if (mode === 'project') {
    // Query based on current project context
    const projectDir = args[1] || process.cwd();
    const queryText = buildQueryFromProject(projectDir);

    queryContext(queryText)
      .then(context => {
        if (context) {
          console.log(context);
        }
      })
      .catch(console.error);
  } else if (mode === 'layer') {
    // Query specific layer
    const layer = args[1];
    const sublayer = args[2];

    if (!layer) {
      console.error('Usage: query.ts layer <layer> [sublayer]');
      process.exit(1);
    }

    queryByLayer(layer, sublayer, { includeContent: true })
      .then(results => {
        for (const r of results) {
          console.log(`## ${r.layer}/${r.sublayer}: ${r.summary}\n`);
          if (r.content) {
            console.log(r.content.slice(0, 500));
            console.log('\n---\n');
          }
        }
      })
      .catch(console.error);
  } else if (mode === 'search') {
    // Free-text search
    const searchText = args.slice(1).join(' ');

    if (!searchText) {
      console.error('Usage: query.ts search <query text>');
      process.exit(1);
    }

    queryContext(searchText, { includeContent: true })
      .then(context => console.log(context))
      .catch(console.error);
  } else {
    console.error('Usage: query.ts <project|layer|search> [args...]');
    process.exit(1);
  }
}
